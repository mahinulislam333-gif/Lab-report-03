def coloring(node, color, colors, graph, n):
    for i in range(n):
        if graph[node][i] == 1 and colors[i] == color:
            return False
    return True


def solve(node, colors, graph, n, m):
    if node == n:
        return True

    for color in range(1, m + 1):
        if coloring(node, color, colors, graph, n):
            colors[node] = color

            if solve(node + 1, colors, graph, n, m):
                return True

            colors[node] = 0

    return False


def graphColoring(n, graph, m):
    colors = [0] * n

    if solve(0, colors, graph, n, m):
        print(f"Coloring Possible with {m} Colors")
        print("Color Assignment:", colors)
    else:
        print(f"Coloring Not Possible with {m} Colors")


n, edges, m = map(int, input().split())

graph = []
for i in range(n):
    graph.append([0] * n)

for i in range(edges):
    u, v = map(int, input().split())
    graph[u][v] = 1
    graph[v][u] = 1

graphColoring(n, graph, m)
